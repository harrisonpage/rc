def calculate_luminance(color_hex):
    """Calculate relative luminance of a color (0-1 scale)"""
    # Convert hex to RGB
    r = int(color_hex[0:2], 16) / 255
    g = int(color_hex[2:4], 16) / 255
    b = int(color_hex[4:6], 16) / 255

    # Apply gamma correction
    def adjust(c):
        return c / 12.92 if c <= 0.03928 else ((c + 0.055) / 1.055) ** 2.4

    r = adjust(r)
    g = adjust(g)
    b = adjust(b)

    # Calculate luminance (weighted sum)
    return 0.2126 * r + 0.7152 * g + 0.0722 * b

def get_contrasting_text_color(bg_color_hex):
    """Returns 'black' or 'white' based on background luminance"""
    luminance = calculate_luminance(bg_color_hex)
    # If background is bright (luminance > 0.5), use black text
    # Otherwise use white text
    return "000000" if luminance > 0.5 else "FFFFFF"

def set_terminal_color(color_hex):
    """Set the terminal background and appropriate foreground color"""
    # Convert hex to RGB values (0-65535 range for AppleScript)
    bg_r = int(color_hex[0:2], 16) * 257
    bg_g = int(color_hex[2:4], 16) * 257
    bg_b = int(color_hex[4:6], 16) * 257

    # Get contrasting text color
    fg_color = get_contrasting_text_color(color_hex)
    fg_r = int(fg_color[0:2], 16) * 257
    fg_g = int(fg_color[2:4], 16) * 257
    fg_b = int(fg_color[4:6], 16) * 257

    transparency = -5000

    # AppleScript to set both background and text color
    script = f"""
tell application "terminal"
	tell window 1
		set background color to {{{bg_r}, {bg_g}, {bg_b}, {transparency}}}
		set normal text color to {{{fg_r}, {fg_g}, {fg_b}, {transparency}}}
	end tell
end tell
"""

    p = os.popen("/usr/bin/osascript", "w")
    p.write(script)
    p.close()

